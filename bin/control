#!/bin/bash

#=============================================================#
#  StreamerHelper Container Control Script                    #
#  Usage: ./bin/control <command> [subcommand] [options]      #
#=============================================================#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INFRA_DIR="$(dirname "$SCRIPT_DIR")"
CONFIG_DIR="${STREAMER_HELPER_CONFIG_DIR:-$HOME/.streamer-helper}"
CONFIG_FILE="$CONFIG_DIR/settings.json"
ENV_FILE="$CONFIG_DIR/.docker-env"

DEFAULT_HTTP_PORT=7080
DEFAULT_HTTPS_PORT=7443
DEFAULT_MINIO_API_PORT=7090
DEFAULT_MINIO_CONSOLE_PORT=7091
DEFAULT_INTERNAL_MINIO_ENDPOINT="http://minio:${DEFAULT_MINIO_API_PORT}"
DEFAULT_PUBLIC_MINIO_ENDPOINT="http://localhost:${DEFAULT_MINIO_API_PORT}"

# Compose files
COMPOSE_INFRA="$INFRA_DIR/docker-compose.infra.yml"
COMPOSE_APP="$INFRA_DIR/docker-compose.app.yml"
COMPOSE_DEV="$INFRA_DIR/docker-compose.dev.yml"

# Image settings
DOCKER_REGISTRY="${DOCKER_REGISTRY:-docker.io}"
DOCKER_ORG="${DOCKER_ORG:-umuoy1}"
IMAGE_PREFIX="${IMAGE_PREFIX:-streamerhelper}"
CONTROL_BACKEND_VERSION="${BACKEND_VERSION:-}"
CONTROL_FRONTEND_VERSION="${FRONTEND_VERSION:-}"

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_step() { echo -e "${BLUE}[STEP]${NC} $1"; }

resolve_backend_version() {
    if [ -n "${CONTROL_BACKEND_VERSION:-}" ]; then
        printf '%s' "$CONTROL_BACKEND_VERSION"
    else
        printf 'latest'
    fi
}

resolve_frontend_version() {
    if [ -n "${CONTROL_FRONTEND_VERSION:-}" ]; then
        printf '%s' "$CONTROL_FRONTEND_VERSION"
    else
        printf 'latest'
    fi
}

resolve_backend_image() {
    printf '%s/%s/%s-backend:%s' \
        "$DOCKER_REGISTRY" \
        "$DOCKER_ORG" \
        "$IMAGE_PREFIX" \
        "$(resolve_backend_version)"
}

resolve_frontend_image() {
    printf '%s/%s/%s-frontend:%s' \
        "$DOCKER_REGISTRY" \
        "$DOCKER_ORG" \
        "$IMAGE_PREFIX" \
        "$(resolve_frontend_version)"
}

compose_app() {
    BACKEND_VERSION="$(resolve_backend_version)" \
    FRONTEND_VERSION="$(resolve_frontend_version)" \
    docker compose -f "$COMPOSE_APP" --env-file "$ENV_FILE" "$@"
}

compose_app_dev() {
    BACKEND_VERSION="$(resolve_backend_version)" \
    FRONTEND_VERSION="$(resolve_frontend_version)" \
    docker compose -f "$COMPOSE_APP" -f "$COMPOSE_DEV" --env-file "$ENV_FILE" "$@"
}

is_local_host() {
    case "${1:-}" in
        ""|"localhost"|"127.0.0.1"|"0.0.0.0"|"::1")
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

split_url() {
    local url="${1:-}"
    URL_SCHEME="http"
    URL_HOST=""
    URL_PORT=""
    URL_PATH=""

    local rest="$url"
    if [[ "$rest" == *"://"* ]]; then
        URL_SCHEME="${rest%%://*}"
        rest="${rest#*://}"
    fi

    local host_port="${rest%%/*}"
    if [[ "$rest" == */* ]]; then
        URL_PATH="/${rest#*/}"
    fi

    if [[ "$host_port" == *":"* ]]; then
        URL_HOST="${host_port%%:*}"
        URL_PORT="${host_port##*:}"
    else
        URL_HOST="$host_port"
    fi
}

build_url() {
    local scheme="${1:-http}"
    local host="$2"
    local port="$3"
    local path="$4"

    printf '%s://%s' "$scheme" "$host"
    if [ -n "$port" ]; then
        printf ':%s' "$port"
    fi
    if [ -n "$path" ]; then
        printf '%s' "$path"
    fi
}

normalize_service_connection() {
    local host="$1"
    local port="$2"
    local service_name="$3"
    local default_port="$4"

    if is_local_host "$host"; then
        host="$service_name"
    fi

    if [ -z "$port" ]; then
        port="$default_port"
    fi

    if [ "$host" = "$service_name" ] || [ "$host" = "streamer-$service_name" ]; then
        port="$default_port"
    fi

    printf '%s %s' "$host" "$port"
}

normalize_internal_s3_endpoint() {
    local endpoint="$1"
    local minio_api_port="${2:-$DEFAULT_MINIO_API_PORT}"
    split_url "$endpoint"

    local scheme="${URL_SCHEME:-http}"
    local host="$URL_HOST"
    local port="$URL_PORT"
    local path="$URL_PATH"
    local use_minio_port=false

    if is_local_host "$host" || [ -z "$host" ] || [ "$host" = "minio" ] || [ "$host" = "streamer-minio" ]; then
        host="minio"
        use_minio_port=true
    fi

    if [ "$host" = "minio" ] || [ "$host" = "streamer-minio" ]; then
        host="minio"
        use_minio_port=true
    fi

    if [ "$use_minio_port" = true ]; then
        port="$minio_api_port"
    fi

    build_url "$scheme" "$host" "$port" "$path"
}

normalize_public_s3_endpoint() {
    local endpoint="$1"
    local minio_api_port="$2"
    split_url "$endpoint"

    local scheme="${URL_SCHEME:-http}"
    local host="$URL_HOST"
    local port="$URL_PORT"
    local path="$URL_PATH"

    if [ -z "$host" ] || [ "$host" = "minio" ] || [ "$host" = "streamer-minio" ]; then
        host="localhost"
    fi

    if [ -z "$port" ]; then
        port="$minio_api_port"
    fi

    if { [ "$host" = "localhost" ] || [ "$host" = "127.0.0.1" ] || [ "$host" = "0.0.0.0" ]; } \
        && { [ "$port" = "9000" ] || [ "$port" = "$DEFAULT_MINIO_API_PORT" ]; } \
        && [ "$port" != "$minio_api_port" ]; then
        port="$minio_api_port"
    fi

    build_url "$scheme" "$host" "$port" "$path"
}

#=============================================================#
#  Utility Functions                                          #
#=============================================================#

check_dependencies() {
    if ! command -v docker &> /dev/null; then
        log_error "Docker is not installed. Please install Docker first."
        exit 1
    fi

    if ! docker compose version &> /dev/null; then
        log_error "Docker Compose v2 is required. Please upgrade Docker."
        exit 1
    fi

    if ! command -v jq &> /dev/null; then
        log_error "jq is required. Install it: apt install jq / brew install jq"
        exit 1
    fi
}

check_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        log_error "Configuration not found at $CONFIG_FILE"
        log_error "Run './bin/configure init' first to create configuration."
        exit 1
    fi
}

# Generate .docker-env from settings.json
generate_env_file() {
    log_step "Generating environment file..."

    local app_keys=$(jq -r '.app.keys // empty' "$CONFIG_FILE")
    local app_port=$(jq -r '.app.port // 7001' "$CONFIG_FILE")
    local db_host=$(jq -r '.database.host // "postgres"' "$CONFIG_FILE")
    local db_port=$(jq -r '.database.port // 5432' "$CONFIG_FILE")
    local db_password=$(jq -r '.database.password // empty' "$CONFIG_FILE")
    local db_username=$(jq -r '.database.username // "postgres"' "$CONFIG_FILE")
    local db_name=$(jq -r '.database.database // "streamerhelper"' "$CONFIG_FILE")
    local redis_host=$(jq -r '.redis.host // "redis"' "$CONFIG_FILE")
    local redis_port=$(jq -r '.redis.port // 6379' "$CONFIG_FILE")
    local s3_endpoint=$(jq -r ".s3.endpoint // \"$DEFAULT_INTERNAL_MINIO_ENDPOINT\"" "$CONFIG_FILE")
    local s3_public_endpoint=$(jq -r ".s3.publicEndpoint // \"$DEFAULT_PUBLIC_MINIO_ENDPOINT\"" "$CONFIG_FILE")
    local s3_access_key=$(jq -r '.s3.accessKey // "minioadmin"' "$CONFIG_FILE")
    local s3_secret_key=$(jq -r '.s3.secretKey // empty' "$CONFIG_FILE")
    local s3_bucket=$(jq -r '.s3.bucket // "streamerhelper-archive"' "$CONFIG_FILE")
    local s3_region=$(jq -r '.s3.region // "us-east-1"' "$CONFIG_FILE")
    local http_port=$(jq -r ".http.port // $DEFAULT_HTTP_PORT" "$CONFIG_FILE")
    local https_port=$(jq -r ".http.httpsPort // $DEFAULT_HTTPS_PORT" "$CONFIG_FILE")
    local minio_console_port=$(jq -r ".minio.consolePort // $DEFAULT_MINIO_CONSOLE_PORT" "$CONFIG_FILE")
    local minio_api_port=$(jq -r ".minio.apiPort // $DEFAULT_MINIO_API_PORT" "$CONFIG_FILE")
    local redis_password=$(jq -r '.redis.password // ""' "$CONFIG_FILE")
    local timezone=$(jq -r '.app.timezone // "Asia/Shanghai"' "$CONFIG_FILE")

    if [ -z "$app_keys" ] || [ -z "$db_password" ] || [ -z "$s3_secret_key" ]; then
        log_error "Invalid config: missing app.keys, database.password, or s3.secretKey"
        exit 1
    fi

    local normalized_db
    normalized_db=$(normalize_service_connection "$db_host" "$db_port" "postgres" "5432")
    local normalized_db_host="${normalized_db% *}"
    local normalized_db_port="${normalized_db#* }"

    local normalized_redis
    normalized_redis=$(normalize_service_connection "$redis_host" "$redis_port" "redis" "6379")
    local normalized_redis_host="${normalized_redis% *}"
    local normalized_redis_port="${normalized_redis#* }"

    local normalized_s3_endpoint
    normalized_s3_endpoint=$(normalize_internal_s3_endpoint "$s3_endpoint" "$minio_api_port")
    local normalized_s3_public_endpoint
    normalized_s3_public_endpoint=$(normalize_public_s3_endpoint "$s3_public_endpoint" "$minio_api_port")

    if [ "$app_port" != "7001" ]; then
        log_warn "Docker deployment keeps backend internal port fixed at 7001. Use http.port to change the public access port."
    fi
    if [ "$db_host:$db_port" != "$normalized_db_host:$normalized_db_port" ]; then
        log_warn "Using Docker-internal PostgreSQL connection ${normalized_db_host}:${normalized_db_port} instead of ${db_host}:${db_port}"
    fi
    if [ "$redis_host:$redis_port" != "$normalized_redis_host:$normalized_redis_port" ]; then
        log_warn "Using Docker-internal Redis connection ${normalized_redis_host}:${normalized_redis_port} instead of ${redis_host}:${redis_port}"
    fi
    if [ "$s3_endpoint" != "$normalized_s3_endpoint" ]; then
        log_warn "Using Docker-internal S3 endpoint ${normalized_s3_endpoint} instead of ${s3_endpoint}"
    fi
    if [ "$s3_public_endpoint" != "$normalized_s3_public_endpoint" ]; then
        log_warn "Using browser-facing S3 endpoint ${normalized_s3_public_endpoint} instead of ${s3_public_endpoint}"
    fi

    mkdir -p "$CONFIG_DIR"

    cat > "$ENV_FILE" << EOF
# Auto-generated from settings.json - DO NOT EDIT DIRECTLY
TZ=${timezone}
APP_KEYS=${app_keys}
APP_PORT=7001
TYPEORM_HOST=${normalized_db_host}
TYPEORM_PORT=${normalized_db_port}
TYPEORM_USERNAME=${db_username}
TYPEORM_PASSWORD=${db_password}
TYPEORM_DATABASE=${db_name}
REDIS_HOST=${normalized_redis_host}
REDIS_PORT=${normalized_redis_port}
S3_ENDPOINT=${normalized_s3_endpoint}
S3_PUBLIC_ENDPOINT=${normalized_s3_public_endpoint}
S3_ACCESS_KEY=${s3_access_key}
S3_SECRET_KEY=${s3_secret_key}
S3_BUCKET=${s3_bucket}
S3_REGION=${s3_region}
REDIS_PASSWORD=${redis_password}
HTTP_PORT=${http_port}
HTTPS_PORT=${https_port}
MINIO_CONSOLE_PORT=${minio_console_port}
MINIO_API_PORT=${minio_api_port}
CONFIG_DIR=${CONFIG_DIR}
EOF

    chmod 600 "$ENV_FILE"
}

# Generate pgAdmin configuration files
generate_pgadmin_config() {
    local db_host=$(jq -r '.database.host // "postgres"' "$CONFIG_FILE")
    local db_port=$(jq -r '.database.port // 5432' "$CONFIG_FILE")
    local db_username=$(jq -r '.database.username // "postgres"' "$CONFIG_FILE")
    local db_name=$(jq -r '.database.database // "streamerhelper"' "$CONFIG_FILE")
    local normalized_db
    normalized_db=$(normalize_service_connection "$db_host" "$db_port" "postgres" "5432")
    db_host="${normalized_db% *}"
    db_port="${normalized_db#* }"

    local pgadmin_dir="$CONFIG_DIR/pgadmin"
    mkdir -p "$pgadmin_dir"

    # Generate servers.json
    cat > "$pgadmin_dir/servers.json" << EOF
{
  "Servers": {
    "1": {
      "Name": "StreamerHelper PostgreSQL",
      "Group": "Servers",
      "Host": "${db_host}",
      "Port": ${db_port},
      "MaintenanceDB": "${db_name}",
      "Username": "${db_username}",
      "SSLMode": "prefer"
    }
  }
}
EOF
}

# Sync PostgreSQL password
sync_postgres_password() {
    local config_password=$(jq -r '.database.password' "$CONFIG_FILE")
    local container_name="streamer-postgres"

    # Wait for postgres to be ready
    local max_wait=30
    local waited=0
    while [ $waited -lt $max_wait ]; do
        if docker exec "$container_name" pg_isready -U postgres > /dev/null 2>&1; then
            break
        fi
        sleep 2
        waited=$((waited + 2))
    done

    if [ $waited -ge $max_wait ]; then
        log_warn "PostgreSQL not ready, skipping password sync"
        return
    fi

    # Sync password
    log_step "Syncing PostgreSQL password..."
    if docker exec "$container_name" psql -U postgres -c "ALTER USER postgres WITH PASSWORD '${config_password}';" > /dev/null 2>&1; then
        log_info "PostgreSQL password synced."
    else
        log_warn "Failed to sync PostgreSQL password"
    fi
}

# Wait for service to be healthy
wait_for_healthy() {
    local container=$1
    local max_wait=${2:-120}
    local waited=0

    while [ $waited -lt $max_wait ]; do
        local status=$(docker inspect "$container" --format '{{.State.Health.Status}}' 2>/dev/null || echo "not_found")
        if [ "$status" = "healthy" ]; then
            return 0
        fi
        sleep 3
        waited=$((waited + 3))
        echo "  Waiting for $container... (${waited}s/${max_wait}s) - status: $status"
    done

    return 1
}

# Ensure MinIO bucket exists
ensure_minio_bucket() {
    local bucket=$(jq -r '.s3.bucket // "streamerhelper-archive"' "$CONFIG_FILE")
    local access_key=$(jq -r '.s3.accessKey // "minioadmin"' "$CONFIG_FILE")
    local secret_key=$(jq -r '.s3.secretKey' "$CONFIG_FILE")

    log_step "Ensuring MinIO bucket exists: $bucket"

    # Configure mc alias inside container
    local minio_api_port=$(jq -r ".minio.apiPort // $DEFAULT_MINIO_API_PORT" "$CONFIG_FILE")
    docker exec streamer-minio mc alias set local "http://localhost:${minio_api_port}" "$access_key" "$secret_key" > /dev/null 2>&1

    # Create bucket if not exists
    if docker exec streamer-minio mc ls local/"$bucket" > /dev/null 2>&1; then
        log_info "Bucket '$bucket' already exists"
    else
        if docker exec streamer-minio mc mb local/"$bucket" > /dev/null 2>&1; then
            log_info "Bucket '$bucket' created"
        else
            log_warn "Failed to create bucket '$bucket'"
        fi
    fi
}

#=============================================================#
#  Infrastructure Commands                                    #
#=============================================================#

do_infra_up() {
    echo ""
    echo -e "${CYAN}Starting Infrastructure Services...${NC}"
    echo ""

    check_dependencies
    check_config
    generate_env_file

    log_step "Starting PostgreSQL, Redis, MinIO..."
    docker compose -f "$COMPOSE_INFRA" --env-file "$ENV_FILE" up -d

    log_step "Waiting for services to be healthy..."
    wait_for_healthy "streamer-postgres" 60 || { log_error "PostgreSQL failed to start"; exit 1; }
    wait_for_healthy "streamer-redis" 30 || { log_error "Redis failed to start"; exit 1; }
    wait_for_healthy "streamer-minio" 60 || { log_error "MinIO failed to start"; exit 1; }

    sync_postgres_password
    ensure_minio_bucket

    log_info "Infrastructure services are ready!"
    echo ""
}

do_infra_down() {
    log_step "Stopping infrastructure services..."
    docker compose -f "$COMPOSE_INFRA" down
    log_info "Infrastructure services stopped."
}

#=============================================================#
#  Migration Commands                                         #
#=============================================================#

do_migrate() {
    echo ""
    echo -e "${CYAN}Running Database Migrations...${NC}"
    echo ""

    check_config
    generate_env_file

    # Check if infra is running
    if ! docker ps --format '{{.Names}}' | grep -q "streamer-postgres"; then
        log_error "PostgreSQL is not running. Run './bin/control infra up' first."
        exit 1
    fi

    local use_local_image=false
    local image_to_use
    image_to_use="$(resolve_backend_image)"

    # Check if local image exists
    if [ "${FORCE_REMOTE_BACKEND_IMAGE:-0}" != "1" ] \
        && docker images --format '{{.Repository}}:{{.Tag}}' | grep -q "infra-backend:local"; then
        use_local_image=true
        image_to_use="infra-backend:local"
        log_info "Using local backend image"
    else
        log_info "Using remote backend image: $image_to_use"
    fi

    log_step "Running migrations..."
    docker run --rm \
        --network streamer-network \
        --env-file "$ENV_FILE" \
        --entrypoint "" \
        "$image_to_use" \
        npm run migration:run:prod

    log_info "Migrations completed!"
    echo ""
}

#=============================================================#
#  Application Commands                                       #
#=============================================================#

do_app_up() {
    echo ""
    echo -e "${CYAN}Starting Application Services...${NC}"
    echo ""

    check_dependencies
    check_config
    generate_env_file

    # Check if infra is running
    if ! docker ps --format '{{.Names}}' | grep -q "streamer-postgres"; then
        log_error "Infrastructure services are not running."
        log_error "Run './bin/control infra up' first."
        exit 1
    fi

    log_step "Starting backend, frontend, nginx..."
    compose_app up -d

    log_step "Waiting for backend to be healthy..."
    if ! wait_for_healthy "streamer-backend" 180; then
        log_error "Backend failed to start"
        docker logs streamer-backend --tail 30
        exit 1
    fi

    log_info "Application services are ready!"

    local http_port=$(jq -r ".http.port // $DEFAULT_HTTP_PORT" "$CONFIG_FILE")
    local minio_port=$(jq -r ".minio.consolePort // $DEFAULT_MINIO_CONSOLE_PORT" "$CONFIG_FILE")

    echo ""
    echo -e "${GREEN}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║${NC}  Application:   http://localhost:${http_port}"
    echo -e "${GREEN}║${NC}  MinIO Console: http://localhost:${minio_port}"
    echo -e "${GREEN}╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

do_app_down() {
    check_config
    generate_env_file
    log_step "Stopping application services..."
    compose_app down
    log_info "Application services stopped."
}

#=============================================================#
#  Combined Commands                                          #
#=============================================================#

do_up() {
    echo ""
    echo -e "${CYAN}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}           StreamerHelper Full Deploy                       ${CYAN}║${NC}"
    echo -e "${CYAN}╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""

    do_infra_up
    do_migrate
    do_app_up
}

do_down() {
    log_step "Stopping all services..."
    docker compose -f "$COMPOSE_APP" down 2>/dev/null || true
    docker compose -f "$COMPOSE_INFRA" down 2>/dev/null || true
    log_info "All services stopped."
}

#=============================================================#
#  Development Commands                                       #
#=============================================================#

do_dev_build() {
    local service="${1:-}"

    echo ""
    echo -e "${CYAN}Building Local Images...${NC}"
    echo ""

    check_dependencies
    check_config
    generate_env_file

    if [ -n "$service" ]; then
        log_step "Building $service..."
        compose_app_dev build "$service"
    else
        log_step "Building all services..."
        compose_app_dev build
    fi

    log_info "Build complete!"
}

do_dev_up() {
    echo ""
    echo -e "${CYAN}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}           StreamerHelper Dev Environment                   ${CYAN}║${NC}"
    echo -e "${CYAN}╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""

    check_dependencies
    check_config
    generate_env_file
    generate_pgadmin_config

    # Start infra if not running
    if ! docker ps --format '{{.Names}}' | grep -q "streamer-postgres"; then
        do_infra_up
    else
        log_info "Infrastructure already running"
    fi

    # Build images first
    log_step "Building local images..."
    compose_app_dev build

    # Run migrations before starting app
    do_migrate

    # Start app
    log_step "Starting application services..."
    compose_app_dev up -d

    log_step "Waiting for backend to be healthy..."
    if ! wait_for_healthy "streamer-backend" 180; then
        log_error "Backend failed to start"
        docker logs streamer-backend --tail 30
        exit 1
    fi

    log_info "Dev environment ready!"

    local http_port=$(jq -r ".http.port // $DEFAULT_HTTP_PORT" "$CONFIG_FILE")
    local minio_port=$(jq -r ".minio.consolePort // $DEFAULT_MINIO_CONSOLE_PORT" "$CONFIG_FILE")

    echo ""
    echo -e "${GREEN}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║${NC}  Application:   http://localhost:${http_port}"
    echo -e "${GREEN}║${NC}  MinIO Console: http://localhost:${minio_port}"
    echo -e "${GREEN}║${NC}  pgAdmin:       http://localhost:7505"
    echo -e "${GREEN}╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

do_dev_down() {
    check_config
    generate_env_file
    log_step "Stopping dev environment..."
    compose_app_dev down 2>/dev/null || true
    log_info "Dev environment stopped."
}

do_dev_restart() {
    do_dev_down
    do_dev_up
}

#=============================================================#
#  Status & Logs                                              #
#=============================================================#

do_status() {
    echo ""
    echo -e "${CYAN}StreamerHelper Services Status${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    docker ps -a --filter "name=streamer" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
    echo ""
}

do_logs() {
    local service="${1:-}"
    if [ -n "$service" ]; then
        docker logs -f "streamer-$service"
    else
        # Show logs from all streamer containers
        docker compose -f "$COMPOSE_INFRA" -f "$COMPOSE_APP" logs -f
    fi
}

#=============================================================#
#  Update Commands                                            #
#=============================================================#

do_update_app() {
    local version="${1:-}"

    if [ -n "$version" ]; then
        CONTROL_BACKEND_VERSION="$version"
        CONTROL_FRONTEND_VERSION="$version"
    fi

    local backend_image
    local frontend_image
    backend_image="$(resolve_backend_image)"
    frontend_image="$(resolve_frontend_image)"

    echo ""
    echo -e "${CYAN}Updating Application Images...${NC}"
    echo ""

    check_dependencies
    check_config
    generate_env_file

    log_info "Backend image:  $backend_image"
    log_info "Frontend image: $frontend_image"

    log_step "Pulling application images..."
    compose_app pull backend frontend nginx

    log_step "Stopping current application services..."
    compose_app down

    log_step "Running migrations with updated backend image..."
    FORCE_REMOTE_BACKEND_IMAGE=1 do_migrate

    log_step "Starting updated application services..."
    compose_app up -d --force-recreate

    log_step "Waiting for backend to be healthy..."
    if ! wait_for_healthy "streamer-backend" 180; then
        log_error "Backend failed to start after update"
        docker logs streamer-backend --tail 30
        exit 1
    fi

    log_info "Application update completed!"
    echo ""
}

do_update_infra() {
    echo ""
    echo -e "${CYAN}Updating Infrastructure Images...${NC}"
    echo ""

    check_dependencies
    check_config
    generate_env_file

    log_step "Pulling infrastructure images..."
    docker compose -f "$COMPOSE_INFRA" --env-file "$ENV_FILE" pull

    log_step "Recreating infrastructure services..."
    docker compose -f "$COMPOSE_INFRA" --env-file "$ENV_FILE" up -d --force-recreate

    log_step "Waiting for services to be healthy..."
    wait_for_healthy "streamer-postgres" 60 || { log_error "PostgreSQL failed to become healthy after update"; exit 1; }
    wait_for_healthy "streamer-redis" 30 || { log_error "Redis failed to become healthy after update"; exit 1; }
    wait_for_healthy "streamer-minio" 60 || { log_error "MinIO failed to become healthy after update"; exit 1; }

    sync_postgres_password
    ensure_minio_bucket

    log_info "Infrastructure update completed!"
    echo ""
}

do_update_all() {
    local version="${1:-}"
    check_config
    generate_env_file

    if docker ps --format '{{.Names}}' | grep -Eq '^streamer-(backend|frontend|nginx)$'; then
        log_step "Stopping application services before infrastructure update..."
        compose_app down
    fi

    do_update_infra
    do_update_app "$version"
}

#=============================================================#
#  Help & Main                                                #
#=============================================================#

print_usage() {
    echo ""
    echo -e "${CYAN}Usage:${NC} ./bin/control <command> [subcommand] [options]"
    echo ""
    echo -e "${CYAN}Infrastructure:${NC}"
    echo "  infra up       Start infrastructure (postgres, redis, minio)"
    echo "  infra down     Stop infrastructure"
    echo ""
    echo -e "${CYAN}Database:${NC}"
    echo "  migrate        Run database migrations"
    echo ""
    echo -e "${CYAN}Application:${NC}"
    echo "  app up         Start application services (backend, frontend, nginx)"
    echo "  app down       Stop application services"
    echo ""
    echo -e "${CYAN}Combined:${NC}"
    echo "  up             Start everything (infra + migrate + app)"
    echo "  down           Stop all services"
    echo "  update [t] [v] Update images and recreate services"
    echo "  status         Show service status"
    echo "  logs [service] Show logs (e.g., logs backend)"
    echo ""
    echo -e "${CYAN}Development:${NC}"
    echo "  dev up         Build from source and start (includes pgAdmin)"
    echo "  dev down       Stop dev environment"
    echo "  dev restart    Restart dev environment"
    echo "  dev build [s]  Build images (optionally specify service)"
    echo ""
    echo -e "${CYAN}Examples:${NC}"
    echo "  ./bin/control infra up     # Step 1: Start databases"
    echo "  ./bin/control migrate      # Step 2: Run migrations"
    echo "  ./bin/control app up       # Step 3: Start app"
    echo "  ./bin/control up           # All-in-one"
    echo "  ./bin/control update app   # Update backend/frontend/nginx"
    echo "  ./bin/control update all v1.2.3"
    echo "  ./bin/control dev up       # Development mode"
    echo ""
}

# Main
case "${1:-}" in
    infra)
        case "${2:-}" in
            up) do_infra_up ;;
            down) do_infra_down ;;
            *) log_error "Usage: ./bin/control infra [up|down]"; exit 1 ;;
        esac
        ;;
    migrate)
        do_migrate
        ;;
    app)
        case "${2:-}" in
            up) do_app_up ;;
            down) do_app_down ;;
            *) log_error "Usage: ./bin/control app [up|down]"; exit 1 ;;
        esac
        ;;
    up)
        do_up
        ;;
    down)
        do_down
        ;;
    update)
        case "${2:-all}" in
            app)
                do_update_app "$3"
                ;;
            infra)
                do_update_infra
                ;;
            all)
                do_update_all "$3"
                ;;
            *)
                log_error "Usage: ./bin/control update [app|infra|all] [version]"
                exit 1
                ;;
        esac
        ;;
    status)
        do_status
        ;;
    logs)
        do_logs "$2"
        ;;
    dev)
        case "${2:-}" in
            up) do_dev_up ;;
            down) do_dev_down ;;
            restart) do_dev_restart ;;
            build) do_dev_build "$3" ;;
            *) log_error "Usage: ./bin/control dev [up|down|restart|build]"; exit 1 ;;
        esac
        ;;
    help|--help|-h|"")
        print_usage
        ;;
    *)
        log_error "Unknown command: $1"
        print_usage
        exit 1
        ;;
esac
