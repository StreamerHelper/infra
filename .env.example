# Application
APP_KEYS=your-secret-key-change-in-production

# PostgreSQL
TYPEORM_USERNAME=postgres
TYPEORM_PASSWORD=your-postgres-password
TYPEORM_DATABASE=livestream
TYPEORM_SSL=false

# Redis
REDIS_PASSWORD=
REDIS_DB=0

# MinIO/S3
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=your-minio-secret-key
S3_REGION=us-east-1
S3_BUCKET=livestream-archive

# Ports (optional, defaults shown)
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
